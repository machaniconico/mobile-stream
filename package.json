{
  "name": "mobile-stream",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "tsc -p tsconfig.json && vite build",
    "typecheck": "npm run typecheck:web && npm run typecheck:rn",
    "typecheck:web": "tsc -p tsconfig.json --pretty false",
    "typecheck:rn": "tsc -p tsconfig.rn.json --pretty false",
    "test": "vitest run",
    "test:watch": "vitest",
    "verify:ui": "node scripts/verify-ui.mjs",
    "mobile:start": "react-native start",
    "mobile:ios": "react-native run-ios",
    "mobile:android": "react-native run-android",
    "mobile:bundle:ios": "react-native bundle --platform ios --dev false --entry-file index.js --bundle-output .artifacts/rn/main.ios.jsbundle --assets-dest .artifacts/rn/ios-assets",
    "mobile:bundle:android": "react-native bundle --platform android --dev false --entry-file index.js --bundle-output .artifacts/rn/index.android.bundle --assets-dest .artifacts/rn/android-assets",
    "verify:rn": "npm run mobile:bundle:ios && npm run mobile:bundle:android"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.1.1",
    "lucide-react": "^0.562.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.85.3",
    "react-native-safe-area-context": "^5.5.2",
    "vite": "^7.2.7"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@babel/preset-env": "^7.25.3",
    "@babel/runtime": "^7.25.0",
    "@react-native-community/cli": "20.1.3",
    "@react-native-community/cli-platform-android": "20.1.3",
    "@react-native-community/cli-platform-ios": "20.1.3",
    "@react-native/babel-preset": "0.85.3",
    "@react-native/metro-config": "0.85.3",
    "@react-native/typescript-config": "0.85.3",
    "@types/react": "^19.2.7",
    "@types/react-dom": "19.2.3",
    "playwright-core": "^1.60.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.15"
  },
  "engines": {
    "node": ">=22.11.0"
  }
}
